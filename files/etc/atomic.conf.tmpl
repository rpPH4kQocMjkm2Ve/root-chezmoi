# /etc/atomic.conf

# Note: inline comments start at ' #' (space + hash).
# Values containing a literal ' #' will be truncated at that point.

BTRFS_MOUNT="/run/atomic/temp_root"
NEW_ROOT="/run/atomic/newroot"
ESP="/efi"
KEEP_GENERATIONS=3
MAPPER_NAME="root_crypt"
KERNEL_PARAMS="{{ if .tpm2_unlock }}rd.luks.options=tpm2-device=auto {{ end }}rw slab_nomerge init_on_alloc=1 page_alloc.shuffle=1 pti=on vsyscall=none randomize_kstack_offset=on debugfs=off"

# Default command to run in the snapshot chroot (overrides built-in default)
# Command-line -- CHROOT_COMMAND... overrides this setting
# Note: args with spaces inside are not supported (simple word splitting)
#CHROOT_COMMAND="/usr/bin/pacman -Syu"

# Sign UKI files with sbctl for Secure Boot (requires sbctl)
SBCTL_SIGN=1

# Upgrade guard: block direct pacman -Syu, suggest atomic-upgrade
# Controls both the pacman hook and the /usr/local/bin/pacman wrapper
# Set to 0 to disable (takes effect immediately, no restart needed)
#UPGRADE_GUARD=1

# Upgrade guard: block direct pacman -Syu, suggest atomic-upgrade
# Controls both the pacman hook and the /usr/local/bin/pacman wrapper
# Set to 0 to disable (takes effect immediately, no restart needed)
#UPGRADE_GUARD=1

# Files to copy from /home/<user>/ into isolated home subvolumes
# Space-separated list of paths relative to user home directory
# Used with: atomic-upgrade --separate-home --copy-files "..."
# This sets the default; --copy-files overrides it per invocation
# Note: paths with spaces are not supported
#HOME_COPY_FILES=".bashrc .bash_profile .ssh .gnupg .gitconfig"
